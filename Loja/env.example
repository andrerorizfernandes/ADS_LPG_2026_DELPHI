# ============================================================
#  .env.example — Copie para .env e preencha com seus dados
#  NÃO versione o .env no Git (já está no .gitignore)
# ============================================================

# O nome do arquivo deve ser exatamente ".env" e ele deve ficar 
# no mesmo local do exe da aplicação
# Ambiente: development | production
APP_ENV=development

# ── Banco de Dados (Firebird) ────────────────────────────────

# Caminho completo para o arquivo .fdb
# Windows local:   C:\Sistemas\Loja\database\LOJA.FDB
# Servidor Linux:  /var/db/loja/LOJA.FDB
DB_DATABASE=C:\caminho\para\seu\BANCO.FDB

# Servidor (use 'localhost' para banco local / embedded)
DB_HOST=localhost

# Porta padrão do Firebird
DB_PORT=3050

# Usuário e senha do banco
DB_USERNAME=SYSDBA
DB_PASSWORD=sua_senha_aqui
